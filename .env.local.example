SUMMARIZE_BACKEND=acp
SUMMARIZE_CLI=copilot
SUMMARIZE_CLI_PATH=
SUMMARIZE_MODEL=gpt-5-mini
SUMMARIZE_REASONING_EFFORT=low

# Daemon loop settings (used by `python -m src.scheduler.loop`)
COLLECT_TARGET=3           # number of daily collects before a build is triggered
COLLECT_INTERVAL_SECONDS=18000  # 5 hours between collect runs

SCROLL_COUNT=80
SCROLL_PAUSE_SECONDS=1.5
SUMMARY_TOP_N=50
SUMMARY_SENTENCE_COUNT=5
RAW_RETENTION_DAYS=3

SOURCE_WEIGHT_A=1.5
SOURCE_WEIGHT_B=1.0
SOURCE_WEIGHT_C=0.6

FRESHNESS_WEIGHT=0.20
RELEVANCE_WEIGHT=0.20
DENSITY_WEIGHT=0.15
ORIGINALITY_WEIGHT=0.10
ENGAGEMENT_WEIGHT=0.05
DUPLICATE_PENALTY=0.25
FRONTEND_BOOST_WEIGHT=0.18

OUTPUT_DIR=data/summaries
RAW_DIR=data/raw
X_HOME_URL=https://x.com/
FOCUS_KEYWORDS=
DELETE_RAW_AFTER_SUMMARY=false

# Local CDP (for local Chrome with --remote-debugging-port=9333)
CHROME_USER_DATA_DIR=$HOME/chrome-hermes-profile
CDP_REMOTE_DEBUGGING_HOST=localhost
CDP_REMOTE_DEBUGGING_PORT=9333
CDP_TARGET_URL=about:blank

# Remote CDP (for Amazon Bedrock AgentCore / Browserbase / other managed browser)
# When set, CDP_WS_URL takes precedence over CDP_REMOTE_DEBUGGING_PORT
CDP_WS_URL=
